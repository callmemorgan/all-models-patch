#!/usr/bin/env node

import { chmod, mkdir, readFile, rename, writeFile } from "node:fs/promises";
import { spawn } from "node:child_process";
import { homedir } from "node:os";
import { platform } from "node:os";
import { dirname, join } from "node:path";

const args = new Set(process.argv.slice(2));
const jsonOutput = args.has("--json");
const cachedOnly = args.has("--cached");
const providerArg = process.argv.find((value) => value.startsWith("--provider="));
const providers = providerArg ? providerArg.slice("--provider=".length) : "";
const stateHome = process.env.XDG_STATE_HOME || join(homedir(), ".local", "state");
const cachePath = join(stateHome, "agents-statusline", "foreign-usage.json");
const keyPath = join(homedir(), ".cli-proxy-api", "client-key");
const agyPath = join(homedir(), ".local", "bin", "agy");

function usage() {
  console.error("usage: claude-all-usage [--json] [--cached] [--provider=codex,grok,agy,kimi]");
  process.exit(2);
}

for (const arg of process.argv.slice(2)) {
  if (!["--json", "--cached"].includes(arg) && !arg.startsWith("--provider=")) usage();
}

async function readCache() {
  return JSON.parse(await readFile(cachePath, "utf8"));
}

async function refresh() {
	let agyHelper;
	const wantsAntigravity = !providers || providers.split(",").some((value) => ["agy", "antigravity"].includes(value.trim()));
	if (platform() === "darwin" && wantsAntigravity) {
		agyHelper = spawn("/usr/bin/script", ["-q", "/dev/null", agyPath], { detached: true, stdio: "ignore" });
		agyHelper.unref();
		await new Promise((resolve) => setTimeout(resolve, 1200));
	}
	try {
	const key = (await readFile(keyPath, "utf8")).trim();
  if (!key) throw new Error(`empty proxy credential: ${keyPath}`);
  const url = new URL("http://127.0.0.1:8317/v1/subscription-usage");
  if (providers) url.searchParams.set("providers", providers);
  const response = await fetch(url, { headers: { Authorization: `Bearer ${key}` }, signal: AbortSignal.timeout(12_000) });
  if (!response.ok) throw new Error(`gateway returned HTTP ${response.status}`);
  const next = await response.json();
  await mkdir(dirname(cachePath), { recursive: true, mode: 0o700 });
  const tmp = `${cachePath}.${process.pid}.tmp`;
  await writeFile(tmp, `${JSON.stringify(next, null, 2)}\n`, { mode: 0o600 });
  await chmod(tmp, 0o600);
	await rename(tmp, cachePath);
	return next;
	} finally {
		if (agyHelper?.pid) {
			try { process.kill(-agyHelper.pid, "SIGTERM"); } catch {}
		}
	}
}

function printTable(data) {
  for (const [provider, usage] of Object.entries(data.providers || {})) {
    if (usage.windows?.length) {
      for (const window of usage.windows) {
        const reset = window.resetAt ? ` · resets ${window.resetAt}` : "";
        console.log(`${provider.padEnd(12)} ${window.label}: ${Math.round(window.usedPercent)}%${reset}`);
      }
    } else {
      const cooldown = usage.cooldownAt ? ` until ${usage.cooldownAt}` : "";
      console.log(`${provider.padEnd(12)} ${usage.state} (${usage.mode})${cooldown}`);
    }
  }
}

try {
  const data = cachedOnly ? await readCache() : await refresh();
  if (jsonOutput) console.log(JSON.stringify(data, null, 2));
  else printTable(data);
} catch (error) {
  console.error(`claude-all-usage: ${error.message}`);
  process.exit(1);
}
