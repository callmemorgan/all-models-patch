#!/usr/bin/env node
import { execFileSync } from "node:child_process";
import { readFileSync, statSync } from "node:fs";
import { basename, join, resolve } from "node:path";
import { fileURLToPath } from "node:url";
import { validateReleaseManifest, verifyReleaseManifestSignature } from "../src/release-manifest.mjs";
import { fileSha256 } from "../src/support-pack.mjs";

const root = resolve(fileURLToPath(new URL("..", import.meta.url)));
const version = JSON.parse(readFileSync(join(root, "package.json"), "utf8")).version;
const head = execFileSync("/usr/bin/git", ["-C", root, "rev-parse", "HEAD"], { encoding: "utf8" }).trim();
const manifestPath = join(root, "dist", "release-manifest.json");
const signaturePath = `${manifestPath}.sig`;
const allowedSignersPath = join(root, "config", "release-signers");
const archive = join(root, "dist", `all-models-patch-${version}-darwin-arm64.tar.gz`);
const manifest = verifyReleaseManifestSignature({ manifestPath, signaturePath, allowedSignersPath });

validateReleaseManifest(manifest);
if (manifest.managerVersion !== version) throw new Error("release manifest version does not match package version");
if (manifest.sourceCommit !== head) throw new Error("release artifacts were not built from the current commit");
if (manifest.assets.bundle.name !== basename(archive)) throw new Error("release manifest bundle name is invalid");
if (manifest.assets.bundle.size !== statSync(archive).size) throw new Error("release bundle size does not match manifest");
if (manifest.assets.bundle.sha256 !== fileSha256(archive)) throw new Error("release bundle hash does not match manifest");

console.log(`Verified release ${version} from ${head}.`);
