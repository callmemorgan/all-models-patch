#!/usr/bin/env node
import { createHash } from "node:crypto";
import { mkdirSync, readFileSync, writeFileSync } from "node:fs";
import { dirname, relative, resolve } from "node:path";
import { analyzeClaudeBinary, KNOWN_BUILDS } from "../src/claude-context-analyzer.mjs";
import { reviewedRecipesForClaude205 } from "../src/claude-2.1.205-recipes.mjs";
import { reviewedGatewayPricingRecipe } from "../src/claude-gateway-pricing-recipe.mjs";
import {
  ALL_FEATURE_IDS,
  FEATURE_GROUPS,
  FEATURE_PACK_SCHEMA,
  FEATURE_PATCHER_VERSION,
  enumerateFeatureSelections,
  featureProfileKey,
} from "../src/features.mjs";
import { applySupportPack, fileSha256 } from "../src/support-pack.mjs";

const CURRENT_REVIEWED_STABLE = "2.1.205";
const version = process.argv[2] ?? CURRENT_REVIEWED_STABLE;
if (version !== CURRENT_REVIEWED_STABLE) {
  throw new Error(`support generation is forward-only; current reviewed Stable is ${CURRENT_REVIEWED_STABLE}`);
}
const source = resolve(process.argv[3] ?? `${process.env.HOME}/.local/share/claude-stable/versions/${version}/claude`);
const output = resolve(process.argv[4] ?? `support/darwin-arm64/${version}-p${FEATURE_PATCHER_VERSION}.json`);

const known = KNOWN_BUILDS[version];
if (!known) throw new Error(`Claude ${version} is not a known build`);
const analysis = analyzeClaudeBinary(source, { version });
const stock = readFileSync(source);
const baseRecipes = reviewedRecipesForClaude205(stock.toString("latin1"));
const recipes = Object.freeze([...baseRecipes, reviewedGatewayPricingRecipe(stock.toString("latin1"))]);
const groups = FEATURE_GROUPS.map(({ id, recipeIds, requires }) => ({ id, recipeIds: [...recipeIds], requires: [...requires] }));
const profiles = Object.fromEntries(enumerateFeatureSelections().map((enabled) => {
  const enabledGroups = new Set(enabled);
  const enabledRecipeIds = new Set(FEATURE_GROUPS.filter((group) => enabledGroups.has(group.id)).flatMap((group) => group.recipeIds));
  return [featureProfileKey(enabled), patchedHash(stock, recipes.filter((recipe) => enabledRecipeIds.has(recipe.id)))];
}));
const defaultProfile = featureProfileKey(ALL_FEATURE_IDS);
const draft = {
  schemaVersion: 2,
  id: `darwin-arm64/${version}/${analysis.sha256}/patcher-${FEATURE_PATCHER_VERSION}`,
  claudeVersion: version,
  platform: "darwin-arm64",
  architecture: "arm64",
  patchEngineSchema: 2,
  patcherVersion: FEATURE_PATCHER_VERSION,
  stock: {
    sha256: analysis.sha256,
    size: analysis.size,
    appleTeamIdentifier: "Q6L2SF6YDW",
  },
  expectedUnsignedPatchedSha256: profiles[defaultProfile],
  analysis: {
    attributionOffset: analysis.attributionOffset,
    gatewayFilterOffset: analysis.gatewayFilterOffset,
    gatewayBootstrapOffset: analysis.gatewayBootstrapOffset,
    contextResolverOffset: analysis.contextResolverOffset,
    compactResolverOffset: analysis.compactResolverOffset,
    contextCallCount: analysis.contextCallCount,
    compactCallCount: analysis.compactCallCount,
  },
  recipes,
  features: {
    schemaVersion: FEATURE_PACK_SCHEMA,
    default: [...ALL_FEATURE_IDS],
    groups,
    profiles,
  },
};

applySupportPack(stock, draft);

mkdirSync(dirname(output), { recursive: true });
writeFileSync(output, `${JSON.stringify(draft, null, 2)}\n`, { mode: 0o644 });
console.log(`wrote ${relative(process.cwd(), output)} (${fileSha256(output)})`);

function patchedHash(stockBinary, selectedRecipes) {
  const patched = Buffer.from(stockBinary);
  for (const recipe of selectedRecipes) {
    const original = Buffer.from(recipe.original);
    const replacement = Buffer.from(recipe.replacement);
    const offset = patched.indexOf(original);
    if (offset < 0 || patched.indexOf(original, offset + 1) >= 0) throw new Error(`recipe is missing or ambiguous: ${recipe.id}`);
    patched.fill(0x20, offset, offset + original.length);
    replacement.copy(patched, offset);
  }
  return fileHash(patched);
}

function fileHash(value) {
  return createHash("sha256").update(value).digest("hex");
}
