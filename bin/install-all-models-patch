#!/bin/zsh
set -euo pipefail

readonly source_root="${0:A:h:h}"
readonly manager_source="$source_root/bin/all-models-patch"
readonly install_root="$HOME/.local/share/all-models-patch"
readonly local_bin="$HOME/.local/bin"
readonly launch_agents="$HOME/Library/LaunchAgents"
readonly logs="$HOME/Library/Logs/all-models-patch"
readonly label="com.callmemorgan.all-models-patch.stable-monitor"
readonly plist="$launch_agents/$label.plist"
readonly expected_team_id="5LTMYWRTYR"
readonly expected_authority="Developer ID Application: MORGANA FAYE ALLEN ($expected_team_id)"

self_update=false
typeset -a agent_teams_args
agent_teams_args=()
for argument in "$@"; do
  case "$argument" in
    --self-update)
      self_update=true
      ;;
    --agent-teams|--no-agent-teams)
      if (( ${#agent_teams_args[@]} > 0 )); then
        print -u2 "all-models-patch: --agent-teams and --no-agent-teams are mutually exclusive"
        exit 1
      fi
      agent_teams_args+=("$argument")
      ;;
    *)
      print -u2 "usage: install-all-models-patch [--agent-teams | --no-agent-teams]"
      print -u2 "       install-all-models-patch --self-update"
      exit 1
      ;;
  esac
done
if [[ "$self_update" == true && ${#agent_teams_args[@]} -gt 0 ]]; then
  print -u2 "all-models-patch: --self-update cannot be combined with an agent-teams choice"
  exit 1
fi

if [[ "$(uname -s)" != "Darwin" || "$(uname -m)" != "arm64" ]]; then
  print -u2 "all-models-patch: only Apple Silicon macOS is supported"
  exit 1
fi
if [[ ! -x "$manager_source" ]]; then
  print -u2 "all-models-patch: release archive is incomplete"
  exit 1
fi
if ! /usr/bin/codesign --verify --strict --verbose=4 "$manager_source"; then
  print -u2 "all-models-patch: manager Developer ID signature is invalid"
  exit 1
fi
readonly signature_detail="$(/usr/bin/codesign -d --verbose=4 "$manager_source" 2>&1)"
if [[ "$signature_detail" != *"Authority=$expected_authority"* || "$signature_detail" != *"TeamIdentifier=$expected_team_id"* || "$signature_detail" != *"(runtime)"* || "$signature_detail" != *"Timestamp="* ]]; then
  print -u2 "all-models-patch: manager is not a hardened, timestamped project Developer ID build"
  exit 1
fi
readonly version="$(ALL_MODELS_PATCH_HOME="$source_root" "$manager_source" doctor --json | /usr/bin/sed -n 's/.*"managerVersion": "\([^"]*\)".*/\1/p')"
if [[ -z "$version" ]]; then
  print -u2 "all-models-patch: could not read the signed manager version"
  exit 1
fi
readonly release_root="$install_root/releases/$version"
readonly temporary="$install_root/.release-$version-$$"

/bin/rm -rf "$temporary"
/bin/mkdir -p "$install_root/releases" "$local_bin" "$launch_agents" "$logs"
/usr/bin/ditto "$source_root" "$temporary"
/usr/bin/codesign --verify --strict --verbose=4 "$temporary/bin/all-models-patch"
ALL_MODELS_PATCH_HOME="$temporary" "$temporary/bin/all-models-patch" doctor >/dev/null
/bin/rm -rf "$release_root"
/bin/mv "$temporary" "$release_root"

readonly next_current="$install_root/.current-$$"
/bin/rm -f "$next_current"
/bin/ln -s "$release_root" "$next_current"
/bin/mv -hf "$next_current" "$install_root/current"
/bin/ln -sfn "$install_root/current/bin/all-models-patch" "$local_bin/all-models-patch"
/bin/ln -sfn "$install_root/current/bin/claude-all" "$local_bin/claude-all"
/bin/ln -sfn "$install_root/current/bin/claude-stable" "$local_bin/claude-stable"

"$local_bin/all-models-patch" provision-model-configs

/usr/bin/ditto "$source_root/config/stable-monitor.plist" "$plist"
/usr/libexec/PlistBuddy -c "Set :ProgramArguments:0 $local_bin/all-models-patch" "$plist"
/usr/libexec/PlistBuddy -c "Set :StandardOutPath $logs/stable-monitor.stdout.log" "$plist"
/usr/libexec/PlistBuddy -c "Set :StandardErrorPath $logs/stable-monitor.stderr.log" "$plist"
/usr/bin/plutil -lint "$plist" >/dev/null

if [[ "$self_update" != true ]]; then
  "$local_bin/all-models-patch" configure --if-unset --no-update "${agent_teams_args[@]}"
  /bin/launchctl bootout "gui/$UID/$label" 2>/dev/null || true
  /bin/launchctl bootstrap "gui/$UID" "$plist"
  "$local_bin/all-models-patch" check --no-self-update
fi
print "Installed all-models-patch $version"
