#!/bin/zsh
set -euo pipefail

readonly root="${0:A:h:h}"
readonly version="$(node -p 'require(process.argv[1]).version' "$root/package.json")"
readonly tag="v$version"
readonly archive="$root/dist/all-models-patch-$version-darwin-arm64.tar.gz"
readonly manifest="$root/dist/release-manifest.json"
readonly signature="$manifest.sig"
readonly signers="$root/config/release-signers"

if [[ -n "$(git -C "$root" status --porcelain --untracked-files=all)" ]]; then
  print -u2 "publish-release: the complete worktree must be clean and committed"
  exit 1
fi

node "$root/bin/prepare-release"
node "$root/bin/verify-release-artifacts"
node "$root/bin/notarize-release"

/usr/bin/git -C "$root" tag -s "$tag" -m "all-models-patch $version"
/usr/bin/git -C "$root" push origin "$tag"
gh release create "$tag" "$archive" "$manifest" "$signature" "$signers" --repo callmemorgan/all-models-patch --title "all-models-patch $version" --generate-notes
